{
  "name": "cardbazar",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android:dev:run": "cross-env ENVFILE=.env.dev react-native run-android",
    "android:prod:run": "cross-env ENVFILE=.env.prod react-native run-android",
    "build:index:android:prod": "cross-env ENVFILE=.env.prod react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && node scripts/obfuscate-bundle.js android/app/src/main/assets/index.android.bundle",
    "build:index:android:dev": "cross-env ENVFILE=.env.dev react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && node scripts/obfuscate-bundle.js android/app/src/main/assets/index.android.bundle",
    "build:android:apk:prod": "cd android && cross-env ENVFILE=.env.prod ./gradlew assembleRelease",
    "build:android:apk:dev": "cd android && cross-env ENVFILE=.env.dev ./gradlew assembleRelease",
    "build:android:aab:prod": "cd android && cross-env ENVFILE=.env.prod ./gradlew bundleRelease",
    "gradle:clean:dev": "cd android && cross-env ENVFILE=.env.dev ./gradlew clean",
    "gradle:clean:prod": "cd android && cross-env ENVFILE=.env.prod ./gradlew clean",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native/new-app-screen": "0.85.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "axios": "^1.15.0",
    "formik": "^2.4.9",
    "jail-monkey": "^2.8.5",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-calendars": "^1.1314.0",
    "react-native-config": "^1.6.1",
    "react-native-device-info": "^15.0.2",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-responsive-screen": "^1.4.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-share": "^12.2.6",
    "react-native-toast-notifications": "^3.4.0",
    "react-native-worklets": "^0.8.1",
    "yup": "^1.7.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@react-native/metro-config": "0.85.0",
    "@react-native/typescript-config": "0.85.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.19.0",
    "javascript-obfuscator": "^5.4.1",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
